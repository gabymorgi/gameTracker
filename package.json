    "antd": "^6.3.5",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "d3-color": "^3.1.0",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.1",
    "jwt-decode": "^4.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-intersection-observer": "^10.0.3",
