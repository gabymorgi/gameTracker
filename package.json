    "globals": "^17.4.0",
    "netlify-cli": "^24.10.0",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.1",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
